  "terminal": {
    "background": "#000000",
    "foreground": "#f5f5f7",
    "cursor": "#ffffff",
    "black": "#18181b",
    "red": "#ef4444",
    "green": "#22c55e",
    "yellow": "#eab308",
    "blue": "#3b82f6",
    "magenta": "#a855f7",
    "cyan": "#06b6d4",
    "white": "#e5e5e5",
    "brightBlack": "#52525b",
    "brightRed": "#f87171",
    "brightGreen": "#4ade80",
    "brightYellow": "#facc15",
    "brightBlue": "#60a5fa",
    "brightMagenta": "#c084fc",
    "brightCyan": "#22d3ee",
    "brightWhite": "#fafafa"
  },
  "syntax": {
    "keyword": "#c084fc",
    "string": "#4ade80",
    "comment": "#52525b",
    "number": "#fbbf24",
    "function": "#60a5fa",
    "type": "#22d3ee"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#52525b", "fontStyle": "italic" }
    },
    {
      "scope": ["constant", "entity.name.constant", "variable.other.constant", "variable.language"],
      "settings": { "foreground": "#fbbf24" }
    },
    {
      "scope": ["entity", "entity.name"],
      "settings": { "foreground": "#60a5fa" }
    },
    {
      "scope": "variable.parameter.function",
      "settings": { "foreground": "#f5f5f7" }
    },
    {
      "scope": "entity.name.tag",
      "settings": { "foreground": "#4ade80" }
    },
    {
      "scope": "keyword",
      "settings": { "foreground": "#c084fc" }
    },
    {
      "scope": ["storage", "storage.type"],
      "settings": { "foreground": "#c084fc" }
    },
    {
      "scope": ["string", "punctuation.definition.string", "string punctuation.section.embedded source"],
      "settings": { "foreground": "#4ade80" }
    },
    {
      "scope": "support",
      "settings": { "foreground": "#22d3ee" }
    },
    {
      "scope": "variable",
      "settings": { "foreground": "#f5f5f7" }
    },
    {
      "scope": "variable.other",
      "settings": { "foreground": "#e5e5e5" }
    }
  ],
  "semanticHighlighting": true
}
