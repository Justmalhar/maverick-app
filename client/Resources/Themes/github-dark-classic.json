  "terminal": {
    "background": "#24292e",
    "foreground": "#e1e4e8",
    "cursor": "#c8e1ff",
    "black": "#586069",
    "red": "#f97583",
    "green": "#85e89d",
    "yellow": "#ffab70",
    "blue": "#79b8ff",
    "magenta": "#b392f0",
    "cyan": "#9ecbff",
    "white": "#e1e4e8",
    "brightBlack": "#6a737d",
    "brightRed": "#fdaeb7",
    "brightGreen": "#85e89d",
    "brightYellow": "#ffab70",
    "brightBlue": "#c8e1ff",
    "brightMagenta": "#b392f0",
    "brightCyan": "#dbedff",
    "brightWhite": "#f0f6fc"
  },
  "syntax": {
    "keyword": "#f97583",
    "string": "#9ecbff",
    "comment": "#6a737d",
    "number": "#79b8ff",
    "function": "#b392f0",
    "type": "#b392f0"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#6a737d" }
    },
    {
      "scope": ["constant", "entity.name.constant", "variable.other.constant", "variable.language"],
      "settings": { "foreground": "#79b8ff" }
    },
    {
      "scope": ["entity", "entity.name"],
      "settings": { "foreground": "#b392f0" }
    },
    {
      "scope": "variable.parameter.function",
      "settings": { "foreground": "#e1e4e8" }
    },
    {
      "scope": "entity.name.tag",
      "settings": { "foreground": "#85e89d" }
    },
    {
      "scope": "keyword",
      "settings": { "foreground": "#f97583" }
    },
    {
      "scope": ["storage", "storage.type"],
      "settings": { "foreground": "#f97583" }
    },
    {
      "scope": ["string", "punctuation.definition.string", "string punctuation.section.embedded source"],
      "settings": { "foreground": "#9ecbff" }
    },
    {
      "scope": "support",
      "settings": { "foreground": "#79b8ff" }
    },
    {
      "scope": "variable",
      "settings": { "foreground": "#ffab70" }
    },
    {
      "scope": "variable.other",
      "settings": { "foreground": "#e1e4e8" }
    }
  ],
  "semanticHighlighting": true
}
